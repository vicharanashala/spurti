# ─── P2P Challenge Dev Mode ───────────────────────────────────────────────────
#
# IMPORTANT: This project uses Vite, NOT Create React App.
# Vite env vars MUST be prefixed with VITE_ and are accessed via
# import.meta.env.VITE_* inside the client source code.
#
# process.env.REACT_APP_* is NOT available in Vite builds.
#
# ── Usage ─────────────────────────────────────────────────────────────────────
#
#  1. Copy this file to client/.env.local  (gitignored, local only):
#       cp client/.env.example client/.env.local
#
#  2. Set VITE_DEV_MODE=true to bypass Samagama cookie auth for local testing.
#     A yellow banner appears in the UI and all auth-gated endpoints return
#     mock/empty data instead of 401.
#
#  3. NEVER commit .env.local or set VITE_DEV_MODE=true in .env.production.
#
# ── Variables ─────────────────────────────────────────────────────────────────

# Bypass Samagama auth in the ChallengeBrowser / ActiveChallengesWidget.
# DEV ONLY — keep false in all shared / production environments.
# Alias requested for CRA compatibility (not functional in Vite):
#   REACT_APP_DEV_MODE=false
VITE_DEV_MODE=false
