# Local development defaults. Copy to `.env` and edit if needed.
PORT=5290
MONGO_URI=mongodb://127.0.0.1:27017/spurti_dev
ALLOW_STUDENT_SEARCH=true
ALLOWED_ORIGINS=http://localhost:5290,http://localhost:5291

# --- Admin authentication (REQUIRED in production) ---
# Generate a secure random token: openssl rand -hex 32
ADMIN_EMAIL=your-admin@email.com
ADMIN_TOKEN=generate-a-strong-random-token-here

# --- Samagama auth endpoint (dev: same host; prod: http://127.0.0.1:5001) ---
SAMAGAMA_AUTH_URL=http://127.0.0.1:5001/api/auth/me

# --- Mandatory survey pop-up (perception triangulation) ---
# Leave SURVEY_ENABLED unset/0 to keep the modal off entirely.
SURVEY_ENABLED=0
# Published Google Form URL (the .../viewform link).
SURVEY_FORM_URL=
# Email field's prefill id, e.g. entry.1234567890 — from the form's "Get pre-filled link".
SURVEY_EMAIL_ENTRY=
# 'hard' = blocking/mandatory (default), 'soft' = dismissable.
SURVEY_ENFORCEMENT=hard
# Auto-expiry (ISO 8601 with offset). After this the modal stops showing — no
# redeploy needed. Empty = no expiry. e.g. 2026-06-30T23:59:59+05:30
SURVEY_DEADLINE=
# Shared secret the Google Apps Script webhook must send to mark a student done.
SURVEY_WEBHOOK_SECRET=
