# Local development defaults. Copy to `.env` and edit if needed.
PORT=5290
MONGO_URI=mongodb://127.0.0.1:27017/analysis_summership
ALLOW_STUDENT_SEARCH=true
SPURTI_AUTH_SECRET=local-dev-only-change-this
SPURTI_COOKIE_SECURE=false

# --- Mandatory survey pop-up (perception triangulation) ---
# Leave SURVEY_ENABLED unset/0 to keep the modal off entirely.
SURVEY_ENABLED=0
# Published Google Form URL (the .../viewform link).
SURVEY_FORM_URL=
# Email field's prefill id, e.g. entry.1234567890 — from the form's "Get pre-filled link".
SURVEY_EMAIL_ENTRY=
# 'hard' = blocking/mandatory (default), 'soft' = dismissable.
SURVEY_ENFORCEMENT=hard
# Auto-expiry (ISO 8601 with offset). After this the modal stops showing — no
# redeploy needed. Empty = no expiry. e.g. 2026-06-30T23:59:59+05:30
SURVEY_DEADLINE=
# Shared secret the Google Apps Script webhook must send to mark a student done.
SURVEY_WEBHOOK_SECRET=

# --- "Your Week, Told" AI weekly recap ---
# Routed through Samagama's own OpenAI-compatible API gateway (samagama.in/platform
# -> API Keys), not OpenAI directly. Required for /api/students/:id/recap and
# server/generateWeeklyRecap.js to generate real narratives.
# If RECAP_API_KEY is unset, a templated (non-AI) narrative is used instead so the
# feature still works end-to-end without API access.
RECAP_API_KEY=
RECAP_API_BASE_URL=https://samagama.in/platform/proxy/v1
RECAP_MODEL=MiniMaxAI/MiniMax-M2.7
