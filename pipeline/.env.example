# Spurti SP pipeline — required environment.
# The live deployment reads these from /var/samagama/server/.env (mode 600,
# samagama user). NEVER commit a filled-in .env — only this example.

# MongoDB. The pipeline derives per-DB connection strings from this base by
# swapping the trailing /<db>?<query>, and connects with authSource=admin to:
#   chatengine, zoom_data, sakshi_spurti, form_responses,
#   rohit_spandan, aditya_platform
MONGO_URI=mongodb://<user>:<password>@<host>:27017/chatengine?authSource=admin

# Zoom Server-to-Server OAuth (used by zoom-update.js, zoom-fetch-transcripts.js,
# zoom-ingest-all-transcripts.js, sp-rubric-build.js)
ZOOM_ACCOUNT_ID=<zoom-s2s-account-id>
ZOOM_CLIENT_ID=<zoom-s2s-client-id>
ZOOM_CLIENT_SECRET=<zoom-s2s-client-secret>

# Optional feature flags
# SKIP_SAKSHI_MIRROR=1      # zoom-update.js: skip the zoom_data -> sakshi_spurti mirror
# SKIP_TRANSCRIPT_INGEST=1  # zoom-update.js: skip chained transcript ingest
# DRY_RUN=1                 # sync-* scripts: count + sample, no writes
# APPLY=1                   # sp-rubric-build.js: enable DB writes (default is dry preview)
# OUT_DIR=./sp-runs         # sp-rubric-build.js: where ledger/set-aside CSV backups land

# NTFY
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=spurti-announcements